{% extends 'layout.html.twig' %}

{% block title %}{{ article.title }} — SkillHub{% endblock %}

{% block body %}

{% set catColors = {
    'Carrière':          {bg:'#fef3c7', color:'#92400e'},
    'Développement Web': {bg:'#dbeafe', color:'#1d4ed8'},
    'DevOps':            {bg:'#fef3c7', color:'#92400e'},
    'Design':            {bg:'#fce7f3', color:'#be185d'},
    'Data Science':      {bg:'#dcfce7', color:'#15803d'}
} %}
{% set c = catColors[article.category] ?? {bg:'#f1f5f9', color:'#475569'} %}

{# ── Header ── #}
<div style="background:#fff; border-bottom:1px solid var(--border); padding:2rem 0 1.5rem;">
    <div class="container" style="max-width:780px;">
        <nav style="font-size:0.75rem; color:var(--muted); margin-bottom:1rem;">
            <a href="{{ path('app_home') }}" style="color:var(--muted);text-decoration:none;">Accueil</a>
            <span class="mx-2">/</span>
            <a href="{{ path('app_articles') }}" style="color:var(--muted);text-decoration:none;">Blog</a>
            <span class="mx-2">/</span>
            <span style="color:var(--text);">{{ article.category }}</span>
        </nav>

        <span class="cat-tag d-inline-flex mb-3" style="background:{{ c.bg }};color:{{ c.color }};">{{ article.category }}</span>
        {% if article.tag %}
            <span class="ms-2 badge-bs">{{ article.tag }}</span>
        {% endif %}

        <h1 style="font-size:2rem; font-weight:800; line-height:1.25; letter-spacing:-0.5px; color:var(--text); margin:0.5rem 0 1rem;">
            {{ article.title }}
        </h1>

        <p style="font-size:1rem; color:var(--muted); line-height:1.7; margin-bottom:1.25rem;">
            {{ article.excerpt }}
        </p>

        <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; font-size:0.82rem; color:var(--muted);">
            <span class="av-init" style="width:30px;height:30px;font-size:0.72rem;">{{ article.authorName|first }}</span>
            <strong style="color:var(--text);">{{ article.authorName }}</strong>
            <span style="color:var(--border);">·</span>
            <span>{{ article.publishedAt }}</span>
            <span style="color:var(--border);">·</span>
            <span><i class="fa-regular fa-clock me-1"></i>{{ article.readTime }} min de lecture</span>
        </div>
    </div>
</div>

{# ── Image ── #}
<div style="background:var(--bg);">
    <div class="container" style="max-width:780px; padding-top:1.5rem;">
        <img src="{{ article.imagePath }}" alt="{{ article.title }}"
             style="width:100%; height:380px; object-fit:cover; border-radius:14px; display:block; border:1px solid var(--border);">
    </div>
</div>

{# ── Contenu + Sidebar ── #}
<div class="container" style="max-width:1100px; padding-top:2rem; padding-bottom:4rem;">
    <div class="row g-5">

        {# Article content #}
        <div class="col-lg-8">
            <div class="article-content">
                {{ article.content|raw }}
            </div>

            {# ── Like ── #}
            <div style="margin-top:2.5rem; padding:1.5rem; background:#fff; border:1px solid var(--border); border-radius:12px; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
                <div>
                    <p style="font-weight:700; font-size:0.95rem; margin:0 0 0.2rem;">Cet article vous a été utile ?</p>
                    <p style="color:var(--muted); font-size:0.82rem; margin:0;">{{ article.likes + (hasLiked ? 1 : 0) }} personne{{ (article.likes + (hasLiked ? 1 : 0)) > 1 ? 's' : '' }} ont aimé cet article.</p>
                </div>
                {% if hasLiked %}
                    <button disabled
                            style="display:flex;align-items:center;gap:0.5rem;background:#fef2f2;color:#f43f5e;border:1px solid #fecaca;border-radius:9px;padding:0.6rem 1.25rem;font-size:0.875rem;font-weight:700;font-family:inherit;cursor:not-allowed;">
                        <i class="fa-solid fa-heart"></i> Aimé !
                    </button>
                {% else %}
                    <form action="{{ path('app_article_like', {slug: article.slug}) }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('like_' ~ article.slug) }}">
                        <button type="submit"
                                style="display:flex;align-items:center;gap:0.5rem;background:#fff;color:var(--text);border:1px solid var(--border);border-radius:9px;padding:0.6rem 1.25rem;font-size:0.875rem;font-weight:600;font-family:inherit;cursor:pointer;transition:all 0.15s;"
                                onmouseover="this.style.borderColor='#f43f5e';this.style.color='#f43f5e'"
                                onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text)'">
                            <i class="fa-regular fa-heart"></i> J'aime cet article
                        </button>
                    </form>
                {% endif %}
            </div>

            {# ── Auteur ── #}
            <div style="margin-top:1.5rem; padding:1.5rem; background:#fff; border:1px solid var(--border); border-radius:12px; display:flex; gap:1rem; align-items:flex-start;">
                <div class="av-init" style="width:48px;height:48px;font-size:1rem;flex-shrink:0;">
                    {{ article.authorName|first }}
                </div>
                <div>
                    <p style="font-weight:700; margin:0 0 0.2rem;">{{ article.authorName }}</p>
                    <p style="color:var(--muted); font-size:0.82rem; margin:0 0 0.5rem;">Formateur expert · SkillHub</p>
                    <p style="font-size:0.82rem; color:var(--text); margin:0;">Professionnel du secteur avec plus de 10 ans d'expérience, passionné par la transmission du savoir et la formation en ligne.</p>
                </div>
            </div>
        </div>

        {# Sidebar #}
        <div class="col-lg-4">
            <div style="position:sticky; top:80px;">

                {# Articles liés #}
                {% if related|length > 0 %}
                <div style="background:#fff; border:1px solid var(--border); border-radius:12px; padding:1.25rem; margin-bottom:1.25rem;">
                    <p style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin-bottom:1rem;">Articles similaires</p>
                    {% for rel in related %}
                        {% set rc = catColors[rel.category] ?? {bg:'#f1f5f9', color:'#475569'} %}
                        <a href="{{ path('app_article_show', {slug: rel.slug}) }}"
                           style="display:block; text-decoration:none; color:inherit; padding:0.75rem 0; border-bottom:1px solid var(--border);"
                           {% if loop.last %}style="display:block; text-decoration:none; color:inherit; padding-top:0.75rem;"{% endif %}>
                            <span class="cat-tag d-inline-flex mb-1" style="background:{{ rc.bg }};color:{{ rc.color }}; font-size:0.65rem;">{{ rel.category }}</span>
                            <p style="font-size:0.83rem; font-weight:600; line-height:1.4; margin:0 0 0.3rem; display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                {{ rel.title }}
                            </p>
                            <span style="font-size:0.73rem; color:var(--muted);">
                                <i class="fa-regular fa-clock me-1"></i>{{ rel.readTime }} min
                                &nbsp;·&nbsp;
                                <i class="fa-regular fa-heart me-1" style="color:#f43f5e;"></i>{{ rel.likes }}
                            </span>
                        </a>
                    {% endfor %}
                </div>
                {% endif %}

                {# CTA cours #}
                <div style="background:linear-gradient(135deg,#4338ca,#6366f1); border-radius:12px; padding:1.5rem; color:#fff;">
                    <p style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:rgba(255,255,255,0.6); margin-bottom:0.5rem;">Formation recommandée</p>
                    <p style="font-weight:800; font-size:1rem; line-height:1.35; margin-bottom:0.75rem;">Passez à la pratique avec nos cours en ligne</p>
                    <a href="{{ path('app_catalog_all') }}"
                       style="display:inline-flex;align-items:center;gap:0.4rem;background:#fff;color:var(--primary);font-weight:700;font-size:0.82rem;padding:0.55rem 1rem;border-radius:8px;text-decoration:none;">
                        Voir le catalogue <i class="fa-solid fa-arrow-right" style="font-size:0.7rem;"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .article-content {
        font-size: 0.97rem;
        line-height: 1.85;
        color: var(--text);
    }
    .article-content h2 {
        font-size: 1.2rem;
        font-weight: 800;
        margin: 2rem 0 0.75rem;
        letter-spacing: -0.2px;
        color: var(--text);
    }
    .article-content p { margin-bottom: 1rem; }
    .article-content ul, .article-content ol {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }
    .article-content li { margin-bottom: 0.4rem; }
    .article-content strong { font-weight: 700; color: var(--text); }
</style>
{% endblock %}
